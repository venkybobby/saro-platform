# SARO Persona RBAC — Environment Variables
# Copy to .env and fill in production values

# Database (RDS Postgres in production, SQLite for dev)
DATABASE_URL=sqlite:///./saro_dev.db
# DATABASE_URL=postgresql://user:pass@host:5432/saro

# JWT Secret (CHANGE THIS IN PRODUCTION)
SARO_JWT_SECRET=change-me-in-production-use-openssl-rand-hex-32

# Admin restrictions
SARO_ADMIN_EMAILS=admin@saro.ai,venkatesan@saro.ai
SARO_ADMIN_IPS=127.0.0.1,::1

# SendGrid (for magic links in production)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@saro.ai

# Stripe (for subscription management)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Logging
SQL_ECHO=false
LOG_LEVEL=INFO

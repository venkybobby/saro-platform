FROM python:3.12-slim

WORKDIR /app

# Install ALL required packages (including structlog and everything else)
RUN pip install --no-cache-dir \
    fastapi uvicorn sqlalchemy psycopg2-binary pydantic \
    passlib[bcrypt] python-jose[cryptography] httpx structlog \
    plotly pandas streamlit

COPY . .

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
FROM python:3.12-slim

WORKDIR /app

# Install all dependencies in one layer
RUN pip install --no-cache-dir \
    fastapi uvicorn sqlalchemy psycopg2-binary pydantic \
    passlib[bcrypt] python-jose[cryptography] httpx structlog \
    plotly pandas

# Copy all files from your repo root
COPY . /app

# Make sure Python can find your modules
ENV PYTHONPATH=/app

EXPOSE 8000

# Run with the flat structure (main:app)
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
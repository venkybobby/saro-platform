FROM python:3.12-slim

WORKDIR /app

COPY requirements.txt* ./
RUN pip install --no-cache-dir -r requirements.txt || pip install streamlit fastapi uvicorn sqlalchemy psycopg2-binary pydantic passlib[bcrypt] python-jose[cryptography] httpx

COPY . .

EXPOSE 8501

CMD ["streamlit", "run", "app.py", "--server.port=8501", "--server.address=0.0.0.0"]